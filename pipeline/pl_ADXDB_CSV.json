{
	"name": "pl_ADXDB_CSV",
	"properties": {
		"activities": [
			{
				"name": "Copy_ADXDB_CSV",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureDataExplorerSource",
						"query": "Sales_Details ",
						"queryTimeout": "01:00:00",
						"noTruncation": false
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "adex_Sales",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "DataSource_Sales",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": []
	}
}