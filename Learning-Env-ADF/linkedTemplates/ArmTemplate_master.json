{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "Learning-Env-ADF"
		},
		"Lnk_ADF_Sales_Source_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Lnk_ADF_Sales_Source'"
		},
		"Lnk_ADF_Sales_Target_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Lnk_ADF_Sales_Target'"
		},
		"Lnk_Blob_Strg_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Lnk_Blob_Strg'"
		},
		"Lnk_Sales_Tgt_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Lnk_Sales_Tgt'"
		},
		"Lnk_pinkzBlob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Lnk_pinkzBlob'"
		},
		"Lnk_ADF_Sales_Source_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pinkz.database.windows.net"
		},
		"Lnk_ADF_Sales_Source_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ADF_Sale_Source"
		},
		"Lnk_ADF_Sales_Source_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pinkz"
		},
		"Lnk_ADF_Sales_Target_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pinkz.database.windows.net"
		},
		"Lnk_ADF_Sales_Target_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ADF_Sales_Target"
		},
		"Lnk_ADF_Sales_Target_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pinkz"
		},
		"Lnk_Sales_Tgt_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "pinkz.database.windows.net"
		},
		"Lnk_Sales_Tgt_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Sales_Tgt"
		},
		"Lnk_Sales_Tgt_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pinkz"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "Learning-Env-ADF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Lnk_ADF_Sales_Source_password": {
						"value": "[parameters('Lnk_ADF_Sales_Source_password')]"
					},
					"Lnk_ADF_Sales_Target_password": {
						"value": "[parameters('Lnk_ADF_Sales_Target_password')]"
					},
					"Lnk_Blob_Strg_connectionString": {
						"value": "[parameters('Lnk_Blob_Strg_connectionString')]"
					},
					"Lnk_Sales_Tgt_password": {
						"value": "[parameters('Lnk_Sales_Tgt_password')]"
					},
					"Lnk_pinkzBlob_connectionString": {
						"value": "[parameters('Lnk_pinkzBlob_connectionString')]"
					},
					"Lnk_ADF_Sales_Source_properties_typeProperties_server": {
						"value": "[parameters('Lnk_ADF_Sales_Source_properties_typeProperties_server')]"
					},
					"Lnk_ADF_Sales_Source_properties_typeProperties_database": {
						"value": "[parameters('Lnk_ADF_Sales_Source_properties_typeProperties_database')]"
					},
					"Lnk_ADF_Sales_Source_properties_typeProperties_userName": {
						"value": "[parameters('Lnk_ADF_Sales_Source_properties_typeProperties_userName')]"
					},
					"Lnk_ADF_Sales_Target_properties_typeProperties_server": {
						"value": "[parameters('Lnk_ADF_Sales_Target_properties_typeProperties_server')]"
					},
					"Lnk_ADF_Sales_Target_properties_typeProperties_database": {
						"value": "[parameters('Lnk_ADF_Sales_Target_properties_typeProperties_database')]"
					},
					"Lnk_ADF_Sales_Target_properties_typeProperties_userName": {
						"value": "[parameters('Lnk_ADF_Sales_Target_properties_typeProperties_userName')]"
					},
					"Lnk_Sales_Tgt_properties_typeProperties_server": {
						"value": "[parameters('Lnk_Sales_Tgt_properties_typeProperties_server')]"
					},
					"Lnk_Sales_Tgt_properties_typeProperties_database": {
						"value": "[parameters('Lnk_Sales_Tgt_properties_typeProperties_database')]"
					},
					"Lnk_Sales_Tgt_properties_typeProperties_userName": {
						"value": "[parameters('Lnk_Sales_Tgt_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}