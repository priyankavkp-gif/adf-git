											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "SoldPrice",
											"type": "Double",
											"physicalType": "real"
										}
									},
									{
										"source": {
											"name": "SoldDate",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "SoldDate",
											"type": "DateTime",
											"physicalType": "datetime"
										}
									},
									{
										"source": {
											"name": "City",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "City",
