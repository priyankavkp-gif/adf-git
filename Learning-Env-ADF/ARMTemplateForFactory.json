											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "SalesPersonLastName",
											"type": "String",
											"physicalType": "string"
										}
									},
									{
										"source": {
											"name": "ProductName",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "Product Name",
											"type": "String",
											"physicalType": "string"
										}
									},
									{
										"source": {
											"name": "ItemsSold",
											"type": "String",
											"physicalType": "String"
										},
										"sink": {
											"name": "ItemsSold",
											"type": "Int32",
											"physicalType": "int"
										}
									},
									{
